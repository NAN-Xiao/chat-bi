ARG PYTHON_BASE_IMAGE=python:3.11-slim-bookworm
ARG POSTGRES_BASE_IMAGE=postgres:17.6
ARG LICENSE_VALIDATOR_URL=
ARG DM_DRIVER_ARCHIVE_URL=

FROM ${PYTHON_BASE_IMAGE} AS python-builder
FROM ${POSTGRES_BASE_IMAGE}
ARG LICENSE_VALIDATOR_URL=
ARG DM_DRIVER_ARCHIVE_URL=

# python environment
COPY --from=python-builder /usr/local /usr/local

RUN python --version && pip --version

# Install uv tool
COPY --from=ghcr.io/astral-sh/uv:0.7.8 /uv /uvx /bin/

RUN apt-get update && apt-get install -y --no-install-recommends \
    wait-for-it \
    build-essential \
    curl \
    ca-certificates \
    gnupg \
    gcc \
    g++ \
    libcairo2-dev \
    libpango1.0-dev \
    libjpeg-dev \
    libgif-dev \
    librsvg2-dev \
    && mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
      | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_20.x nodistro main" \
      > /etc/apt/sources.list.d/nodesource.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends nodejs \
    && node --version \
    && npm --version \
    && if [ -n "$LICENSE_VALIDATOR_URL" ]; then curl -L --connect-timeout 60 -m 1800 "$LICENSE_VALIDATOR_URL" | sh; fi \
    && rm -rf /var/lib/apt/lists/* \
    && chmod g+xr /usr/bin/ld.so \
    && chmod g+x /usr/local/bin/python*

# Download Oracle instant client
ENV DB_CLIENT=/opt/zhishu/db_client
ENV LD_LIBRARY_PATH="${DB_CLIENT}/oracle_instant_client"
ARG TARGETARCH
RUN apt-get update && \
    (apt-get install -y unzip libaio1t64 || apt-get install -y unzip libaio1) && \
    mkdir -p ${DB_CLIENT} && \
    if [ "$TARGETARCH" = "amd64" ]; then \
      echo "Building for x86_64"; \
      curl -L -o app.zip https://download.oracle.com/otn_software/linux/instantclient/2326000/instantclient-basic-linux.x64-23.26.0.0.0.zip; \
    elif [ "$TARGETARCH" = "arm64" ]; then \
      echo "Building for ARM64"; \
      curl -L -o app.zip https://download.oracle.com/otn_software/linux/instantclient/2390000/instantclient-basic-linux.arm64-23.9.0.25.07.zip; \
    fi && \
    unzip app.zip -d ${DB_CLIENT} && \
    rm app.zip && \
    rm -rf /var/lib/apt/lists/* && \
    mv ${DB_CLIENT}/instantclient* ${DB_CLIENT}/oracle_instant_client

# Download DM library
ENV DM_HOME=/opt/dmdbms
ENV LD_LIBRARY_PATH="${DM_HOME}/bin:${LD_LIBRARY_PATH}"
RUN if [ -n "$DM_DRIVER_ARCHIVE_URL" ]; then \
      curl -L -o dm.zip "$DM_DRIVER_ARCHIVE_URL" && \
      mkdir -p $DM_HOME/bin && \
      unzip dm.zip -d $DM_HOME/bin && \
      chmod -R +x $DM_HOME/bin && \
      rm -rf dm.zip; \
    else \
      echo "DM driver archive not configured, skipping"; \
    fi

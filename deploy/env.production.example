# 星通数智 B2B 多租户生产环境变量模板
# 复制到生产环境的私有配置文件后再填写真实值，不要提交真实密钥。

APP_ENV=production
PRODUCTION_CHECKS_ENABLED=true
AUTO_RUN_MIGRATIONS=false
PROJECT_NAME=星通数智

# Web / CORS
FRONTEND_HOST=https://bi.example.com
BACKEND_CORS_ORIGINS=https://bi.example.com
ENABLE_LOCAL_DEV_CORS=false
CONTEXT_PATH=

# Auth / secrets
# 生成示例：python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET
# 用于加密数据源连接配置、大模型 API Key/API 地址等服务端敏感配置。
# 必须长期稳定保存；轮换前需要先完成旧密文迁移。
SENSITIVE_CONFIG_ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_LONG_RANDOM_CONFIG_SECRET
DEFAULT_PWD=CHANGE_ME_STRONG_INITIAL_PASSWORD
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# PostgreSQL system database
POSTGRES_SERVER=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=shuzhi_bi
POSTGRES_USER=shuzhi
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

# PostgreSQL backup job used by deploy/systemd/shuzhi-postgres-backup.timer
BACKUP_DIR=/var/backups/shuzhi/postgres
BACKUP_RETENTION_DAYS=14
PG_DUMP_BIN=pg_dump
PG_RESTORE_BIN=pg_restore

# Redis shared cache and task queue
CACHE_TYPE=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_KEY_PREFIX=shuzhi-prod
CACHE_REDIS_PREFIX=shuzhi-prod-cache
REDIS_MAX_CONNECTIONS=200
TASK_QUEUE_NAME=default
TASK_QUEUE_MAX_ATTEMPTS=3
TASK_QUEUE_RESULT_TTL_SECONDS=86400
TASK_QUEUE_VISIBILITY_TIMEOUT_SECONDS=3600
TASK_QUEUE_REQUEUE_INTERVAL_SECONDS=60
TASK_QUEUE_MAX_PENDING_PER_TENANT=1000
TASK_QUEUE_MAX_PROCESSING_PER_TENANT=10

# Tenant-level high-cost request limits, per 60 seconds
TENANT_RATE_LIMIT_ENABLED=true
TENANT_CHAT_REQUESTS_PER_MINUTE=60
TENANT_ANALYSIS_REQUESTS_PER_MINUTE=20
TENANT_RECOMMEND_REQUESTS_PER_MINUTE=30
TENANT_LLM_REQUESTS_PER_MINUTE=60
# Optional per-plan overrides. Keys may be plan names such as default/basic/enterprise.
# Leave empty to use the global limits above.
TENANT_RATE_LIMIT_PLAN_OVERRIDES={"default":{"chat_requests_per_minute":30,"analysis_requests_per_minute":10,"recommend_requests_per_minute":20},"basic":{"chat_requests_per_minute":60,"analysis_requests_per_minute":20,"recommend_requests_per_minute":30},"enterprise":{"chat_requests_per_minute":180,"analysis_requests_per_minute":60,"recommend_requests_per_minute":90}}

# Tenant usage metering. Keep enabled in production for operations, quota review, and cost audit.
TENANT_USAGE_METERING_ENABLED=true
# Tenant plan quotas backed by sys_tenant_usage_daily. Empty means no hard quota.
TENANT_USAGE_QUOTA_ENABLED=true
TENANT_USAGE_QUOTA_PLAN_LIMITS={"default":{"daily":{"chat":100,"analysis":20,"recommend":100,"task":200},"monthly":{"chat":2000,"analysis":400,"recommend":2000,"task":5000}},"basic":{"daily":{"chat":300,"analysis":60,"recommend":300,"task":1000},"monthly":{"chat":8000,"analysis":1500,"recommend":8000,"task":20000}},"enterprise":{"daily":{"chat":2000,"analysis":400,"recommend":2000,"task":10000},"monthly":{"chat":60000,"analysis":12000,"recommend":60000,"task":300000}}}

# Paths
BASE_DIR=/opt/shuzhi
UPLOAD_DIR=/opt/shuzhi/data/file
EXCEL_PATH=/opt/shuzhi/data/excel
MCP_IMAGE_PATH=/opt/shuzhi/images
LOG_DIR=/opt/shuzhi/logs

# Security switches
MCP_ENABLED=false
SHUZHI_ALLOW_METADATA_QUERIES=false
SQL_DEBUG=false
LOG_LEVEL=INFO

# Database pool
PG_POOL_SIZE=20
PG_MAX_OVERFLOW=30
PG_POOL_RECYCLE=3600
PG_POOL_PRE_PING=true

# Online LLM / embedding
EMBEDDING_ENABLED=true
TABLE_EMBEDDING_ENABLED=true
EMBEDDING_USE_DEFAULT_AI_MODEL_CONFIG=true
EMBEDDING_MODEL=text-embedding-v4

# Observability, optional
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.0

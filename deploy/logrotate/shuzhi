# 星通数智 production log rotation.
# Install to /etc/logrotate.d/shuzhi after adjusting paths if the deployment layout differs.

/opt/shuzhi/logs/*.log
/var/log/nginx/shuzhi.*.log
/var/log/redis/shuzhi-redis.log
{
    daily
    rotate 14
    maxage 30
    compress
    delaycompress
    missingok
    notifempty
    dateext
    copytruncate
    su root root
}
